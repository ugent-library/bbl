package views

import (
	"fmt"
	"slices"
	"sort"

	"github.com/ugent-library/bbl"
	"github.com/ugent-library/vo"
)

templ BackofficeEditWork(c Ctx, work *bbl.Work, profile []bbl.FieldDef, errs vo.Errors) {
	@Layout(c, c.Loc("Edit %s", workTitle(c, work))+" - "+c.Loc("Backoffice")) {
		<main>
			<p><a href={ templ.SafeURL("/backoffice/works/" + work.ID.String()) }>{ c.Loc("Back to work") }</a></p>
			<h1>{ c.Loc("Edit %s", workTitle(c, work)) }</h1>
			<p>{ c.Loc("Kind") }: { work.Kind } | { c.Loc("Status") }: { work.Status }</p>
			if len(errs) > 0 {
				<ul>
					for _, e := range errs {
						<li>{ e.Error() }</li>
					}
				</ul>
			}
			<form method="post" action={ templ.SafeURL(fmt.Sprintf("/backoffice/works/%s/edit", work.ID)) }>
				for _, f := range profile {
					@editField(c, f, work)
				}
				<div>
					<button type="submit">{ c.Loc("Save") }</button>
					<a href={ templ.SafeURL("/backoffice/works/" + work.ID.String()) }>{ c.Loc("Cancel") }</a>
				</div>
			</form>
		</main>
	}
}

templ editField(c Ctx, f bbl.FieldDef, work *bbl.Work) {
	switch f.Type {
		case "string":
			<fieldset>
				<label for={ f.Name }>
					{ fieldLabel(c, f.Name) }
					if f.IsRequired() {
						<span>*</span>
					}
				</label>
				<input
					type="text"
					id={ f.Name }
					name={ f.Name }
					value={ workAttrString(work, f.Name) }
				/>
			</fieldset>
		case "title":
			@editTitleList(c, f, work)
		case "text":
			@editTextList(c, f, work)
		case "keyword":
			@editKeywords(c, work)
		case "extent":
			@editExtent(c, f, work)
		case "conference":
			@editConference(c, f, work)
		case "note":
			@editNoteList(c, f, work)
		case "identifier":
			@showIdentifiers(c, work)
		case "classification":
			@showClassifications(c, work)
		case "workContributor":
			@editContributors(c, work)
	}
}

templ editTitleList(c Ctx, f bbl.FieldDef, work *bbl.Work) {
	<fieldset data-repeatable={ f.Name }>
		<legend>
			{ fieldLabel(c, f.Name) }
			if f.IsRequired() {
				<span>*</span>
			}
		</legend>
		<div data-repeatable-items>
			for _, t := range workAttrTitleList(work) {
				<div data-repeatable-item>
					@langSelect(c, f.Name+".lang", t.Lang)
					<input type="text" name={ f.Name + ".val" } value={ t.Val } placeholder="value"/>
					<button type="button" data-remove-item>{ c.Loc("Remove") }</button>
				</div>
			}
		</div>
		<button type="button" data-add-item>{ c.Loc("Add %s", fieldLabel(c, f.Name)) }</button>
		<template data-item-template>
			<div data-repeatable-item>
				@langSelect(c, f.Name+".lang", "")
				<input type="text" name={ f.Name + ".val" } value="" placeholder="value"/>
				<button type="button" data-remove-item>{ c.Loc("Remove") }</button>
			</div>
		</template>
	</fieldset>
}

