package views

import (
	"net/url"
	"strconv"

	"github.com/ugent-library/bbl"
)

// Discovery search views

templ SearchWorks(c Ctx, hits *bbl.WorkHits, opts *bbl.SearchOpts) {
	@Layout(c, c.Loc("Works")) {
		<main>
			<h1>{ c.Loc("Works") }</h1>
			@searchForm(c, opts, "/works")
			@searchSummary(c, hits.Total, opts)
			if len(hits.Hits) > 0 {
				<table>
					<thead>
						<tr>
							<th>{ c.Loc("Title") }</th>
							<th>{ c.Loc("Kind") }</th>
						</tr>
					</thead>
					<tbody>
						for _, h := range hits.Hits {
							<tr>
								<td><a href={ templ.SafeURL("/works/" + h.ID.String()) }>{ h.Title }</a></td>
								<td>{ h.Kind }</td>
							</tr>
						}
					</tbody>
				</table>
				@pagination(c, hits.Total, opts, "/works")
			}
		</main>
	}
}

