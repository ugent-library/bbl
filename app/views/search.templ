// Shared components

templ searchForm(c Ctx, opts *bbl.SearchOpts, action string) {
	<form action={ templ.SafeURL(action) } method="get">
		<input type="search" name="q" value={ opts.Query } placeholder={ c.Loc("Search...") }/>
		<button type="submit">{ c.Loc("Search") }</button>
	</form>
}

templ searchSummary(c Ctx, total int, opts *bbl.SearchOpts) {
	<p>
		if total == 0 {
			{ c.Loc("No results found.") }
		} else {
			{ c.Loc("Showing %d\u2013%d of %d", opts.Offset+1, min(opts.Offset+opts.Size, total), total) }
		}
	</p>
}

templ pagination(c Ctx, total int, opts *bbl.SearchOpts, baseURL string) {
	if pages := paginationPages(opts.Size, opts.Offset, total, 10); len(pages) > 1 {
		<nav aria-label="Pagination">
			if opts.Offset > 0 {
				<a href={ paginationURL(baseURL, opts.Query, opts.Offset-opts.Size) }>{ c.Loc("Previous") }</a>
			}
			for _, p := range pages {
				{ " " }
				if p.Current {
					<strong>{ strconv.Itoa(p.Number) }</strong>
				} else {
					<a href={ paginationURL(baseURL, opts.Query, p.Offset) }>{ strconv.Itoa(p.Number) }</a>
				}
			}
			{ " " }
			if opts.Offset+opts.Size < total {
				<a href={ paginationURL(baseURL, opts.Query, opts.Offset+opts.Size) }>{ c.Loc("Next") }</a>
			}
		</nav>
	}
}

type paginationPage struct {
	Number  int
	Offset  int
	Current bool
}

// paginationPages returns a sliding window of page numbers centered on the
// current page. Uses clamp-and-shift: centers the window on the current page,
// then shifts it to stay within [1, totalPages], keeping the window full.
func paginationPages(size, offset, total, window int) []paginationPage {
	if size <= 0 || total <= 0 {
		return nil
	}

	totalPages := (total + size - 1) / size
	currentPage := (offset / size) + 1
	if currentPage > totalPages {
		currentPage = totalPages
	}

	window = min(window, totalPages)

	start := max(1, currentPage-(window-1)/2)
	end := start + window - 1
	if end > totalPages {
		end = totalPages
		start = end - window + 1
	}

	pages := make([]paginationPage, 0, window)
	for n := start; n <= end; n++ {
		pages = append(pages, paginationPage{
			Number:  n,
			Offset:  (n - 1) * size,
			Current: n == currentPage,
		})
	}

	return pages
}

func paginationURL(baseURL, query string, offset int) templ.SafeURL {
	params := url.Values{}
	if query != "" {
		params.Set("q", query)
	}
	if offset > 0 {
		params.Set("offset", strconv.Itoa(offset))
	}
	u := baseURL
	if encoded := params.Encode(); encoded != "" {
		u += "?" + encoded
	}
	return templ.SafeURL(u)
}
