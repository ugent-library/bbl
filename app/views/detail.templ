package views

import (
	"encoding/json"

	"github.com/ugent-library/bbl"
)

// Discovery detail views

templ ShowWork(c Ctx, work *bbl.Work) {
	@Layout(c, c.Loc("Work")) {
		<main>
			<p><a href="/works">{ c.Loc("Back to works") }</a></p>
			<h1>{ workTitle(c, work) }</h1>
			<dl>
				<dt>{ c.Loc("Kind") }</dt>
				<dd>{ work.Kind }</dd>
				<dt>{ c.Loc("Status") }</dt>
				<dd>{ work.Status }</dd>
			</dl>
		</main>
	}
}

