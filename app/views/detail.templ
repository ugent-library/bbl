templ BackofficeWorkHistory(c Ctx, work *bbl.Work, history []bbl.WorkHistoryEntry) {
	@Layout(c, c.Loc("History")+" - "+c.Loc("Backoffice")) {
		<main>
			<p><a href={ templ.SafeURL("/backoffice/works/" + work.ID.String()) }>{ c.Loc("Back to work") }</a></p>
			<h1>{ workTitle(c, work) } — { c.Loc("History") }</h1>
			for _, group := range groupAssertionsByField(history) {
				<section>
					<h2>{ group.field }</h2>
					<table>
						<thead>
							<tr>
								<th></th>
								<th>{ c.Loc("Value") }</th>
								<th>{ c.Loc("By") }</th>
								<th>{ c.Loc("Date") }</th>
							</tr>
						</thead>
						<tbody>
							for _, a := range group.assertions {
								<tr>
									<td>
										if a.Pinned {
											<strong>&#9733;</strong>
										} else if a.IsHistory {
											<span style="color:#999;font-size:0.85em">was</span>
										}
									</td>
									<td>
										if a.Hidden {
											<em>{ c.Loc("(hidden)") }</em>
										} else if a.Val == nil {
											{ a.Field }
										} else {
											{ assertionDisplayVal(a) }
										}
									</td>
									<td>
										if a.Source != "" {
											{ a.Source }
										} else if a.UserID != nil {
											{ a.UserID.String() }
											if a.Role != "" {
												({ a.Role })
											}
										}
									</td>
									<td>{ a.RevAt.Format("2006-01-02 15:04") }</td>
								</tr>
							}
						</tbody>
					</table>
				</section>
			}
			if len(history) == 0 {
				<p>{ c.Loc("No assertions.") }</p>
			}
		</main>
	}
}

// Helper functions for display names.

func projectTitle(c Ctx, p *bbl.Project) string {
	for _, t := range p.Titles {
		if t.Val != "" {
			return t.Val
		}
	}
	return c.Loc("(untitled)")
}

func workTitle(c Ctx, w *bbl.Work) string {
	for _, t := range w.Titles {
		if t.Val != "" {
			return t.Val
		}
	}
	return c.Loc("(untitled)")
}

func organizationName(c Ctx, o *bbl.Organization) string {
	for _, n := range o.Names {
		if n.Val != "" {
			return n.Val
		}
	}
	return c.Loc("(unnamed)")
}

type assertionGroup struct {
	field      string
	assertions []bbl.WorkHistoryEntry
}

func groupAssertionsByField(history []bbl.WorkHistoryEntry) []assertionGroup {
	var groups []assertionGroup
	seen := make(map[string]int) // field → index in groups
	for _, a := range history {
		idx, ok := seen[a.Field]
		if !ok {
			idx = len(groups)
			seen[a.Field] = idx
			groups = append(groups, assertionGroup{field: a.Field})
		}
		groups[idx].assertions = append(groups[idx].assertions, a)
	}
	return groups
}

func assertionDisplayVal(a bbl.WorkHistoryEntry) string {
	if a.Val == nil {
		return ""
	}
	var s string
	if json.Unmarshal(a.Val, &s) == nil {
		return s
	}
	// Compound value — show raw JSON.
	return string(a.Val)
}
