# binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bbl

# test binary built with `go test -c`
*.test

# output of the go coverage tool
*.out

# junk files
.DS_Store

# force include empty directories
!.gitkeep

# dotenv
.env
.env.*
!.env.example
.envrc

# direnv
.direnv

# local workspace
go.work*

# tmp
tmp
.tmp

# dependency directories
node_modules

# templ txt files
*_templ.txt

# esbuild output (regenerated by npm run build)
app/static/*
!app/static/.gitkeep

# configuration files
config.yaml

# Claude Code AI session memory (machine-local)
.claude
